<resources>

    <style name="Theme.Batterypulse" parent="android:Theme.Material.Light.NoActionBar" />


    <style name="Theme.Batterypulse.Splash" parent="Theme.SplashScreen">

        <item name="android:windowSplashScreenBackground">#000000</item>

        <!-- Your app icon (should be adaptive icon) -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- After splash, switch to your real app theme -->
        <item name="postSplashScreenTheme">@style/Theme.Batterypulse</item>

    </style>
</resources>